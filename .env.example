# Backend
PORT=5000
NODE_ENV=development

# Database (SQLite en desarrollo, PostgreSQL en producción)
DATABASE_URL="file:./prisma/dev.db"
# Para producción: DATABASE_URL="postgresql://user:password@localhost:5432/asistencias"

# JWT
JWT_SECRET=tu_secreto_super_seguro_cambiar_en_produccion_minimo_32_caracteres

# HMAC para tokens QR
HMAC_SECRET=otro_secreto_para_hmac_cambiar_tambien_minimo_32_caracteres

# Administrador inicial (primera ejecución)
ADMIN_EMAIL=admin@colegio.edu
ADMIN_PASSWORD=Admin123!

# Configuración de trabajos
CRON_DIAGNOSTICS_INTERVAL=0 0 */6 * * *  # cada 6 horas
BACKUP_BEFORE_REPAIR=true

# Logs
LOG_LEVEL=info
