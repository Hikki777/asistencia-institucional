{
  "name": "asistencias-qr",
  "version": "1.0.0",
  "description": "Sistema de control de asistencias por QR con auto-reparación",
  "main": "backend/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "npx nodemon backend/server.js",
    "dev:backend": "npx nodemon backend/server.js",
    "dev:frontend": "cd frontend-react && npm run dev",
    "start": "node start.js && node backend/server.js",
    "pretest": "node setup-test-db.js",
    "test": "cross-env NODE_ENV=test jest --coverage --verbose",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:unit": "cross-env NODE_ENV=test jest --testPathPattern=unit",
    "test:integration": "cross-env NODE_ENV=test jest --testPathPattern=integration",
    "seed": "node backend/prisma/seed.js",
    "prisma:studio": "npx prisma studio",
    "prisma:push": "npx prisma db push",
    "prisma:reset": "npx prisma migrate reset --force",
    "info": "node start.js"
  },
  "keywords": [
    "asistencias",
    "qr",
    "colegio",
    "control"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "archiver": "^6.0.0",
    "axios": "^1.13.1",
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.0",
    "fs-extra": "^11.1.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.2",
    "pdfkit": "^0.17.2",
    "pdfkit-table": "^0.1.99",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.2",
    "qrcode": "^1.5.3",
    "sharp": "^0.32.6",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "jimp": "^1.6.0",
    "jsqr": "^1.4.0",
    "prisma": "^5.0.0",
    "supertest": "^7.1.4"
  }
}
